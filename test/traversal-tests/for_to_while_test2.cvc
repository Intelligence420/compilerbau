extern void printInt(int val);
extern void printNewlines(int n);

export int main() {
  int a = 10;
  int b = 1;
  int c = -3;

  // 5. negative step
  for (int i = 0, 10, -1) {
    printInt(i);
  }
  printNewlines(1);

  // Jesus Test
  for (int j = a, b, c) {
    printInt(j);
  }
  printNewlines(1);

  return 0;
}

