extern void printInt(int val);
extern void printFloat(float val);
extern void printNewlines(int num);

export int main() {
    int i = 10;
    float f = 3.5;
    float f2;
    int i2;
    float f4;
    
    // Int to Float
    f2 = (float)i + f;
    printFloat(f2); // 13.5
    printNewlines(1);
    
    // Float to Int
    i2 = (int)f + i;
    printInt(i2); // 13
    printNewlines(1);
    
    // Complex expression
    f4 = (float)((int)f * i) + 0.5;
    printFloat(f4); // (3 * 10) + 0.5 = 30.5
    printNewlines(1);
    
    return 0;
}
