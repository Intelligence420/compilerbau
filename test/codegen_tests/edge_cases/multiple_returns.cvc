extern void printInt(int val);
extern void printNewlines(int num);

int multi_return(int x) {
    if (x > 10) {
        return 1;
    }
    if (x < 0) {
        return -1;
    }
    return 0;
}

export int main() {
    printInt(multi_return(15)); // 1
    printNewlines(1);
    printInt(multi_return(-5)); // -1
    printNewlines(1);
    printInt(multi_return(5));  // 0
    printNewlines(1);
    
    return 0;
}
