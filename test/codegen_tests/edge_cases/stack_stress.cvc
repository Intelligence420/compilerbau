extern void printInt(int val);
extern void printNewlines(int num);

// Deep recursion
int recurse(int n) {
    if (n <= 0) {
        return 0;
    }
    return 1 + recurse(n - 1);
}

// Many local variables
int many_locals() {
    int v0 = 0;
    int v1 = 1;
    int v2 = 2;
    int v3 = 3;
    int v4 = 4;
    int v5 = 5;
    int v6 = 6;
    int v7 = 7;
    int v8 = 8;
    int v9 = 9;
    int v10 = 10;
    int v11 = 11;
    int v12 = 12;
    int v13 = 13;
    int v14 = 14;
    int v15 = 15;
    int v16 = 16;
    int v17 = 17;
    int v18 = 18;
    int v19 = 19;
    
    return v0+v1+v2+v3+v4+v5+v6+v7+v8+v9+v10+v11+v12+v13+v14+v15+v16+v17+v18+v19;
}

export int main() {
    printInt(recurse(100)); // Test depth 100
    printNewlines(1);
    
    printInt(many_locals()); // (19 * 20) / 2 = 190
    printNewlines(1);
    
    return 0;
}
