extern void printInt(int val);
extern void printNewlines(int num);

export int main() {
    int sum = 0;
    int s1 = 3;
    int s2 = -3;
    
    // Normal loop
    for (int i = 1, 10) {
        sum = sum + i;
    }
    printInt(sum); // (10*11)/2 = 55
    printNewlines(1);
    
    // Loop with explicit step
    sum = 0;
    for (int i = 0, 10, 2) {
        sum = sum + i;
    }
    printInt(sum); // 0+2+4+6+8+10 = 30
    printNewlines(1);
    
    // Reverse loop
    sum = 0;
    for (int i = 10, 1, -2) {
        sum = sum + i;
    }
    printInt(sum); // 10+8+6+4+2 = 30
    printNewlines(1);
    
    // Dynamic step
    sum = 0;
    for (int i = 1, 10, s1) {
        sum = sum + i;
    }
    printInt(sum); // 1 + 4 + 7 + 10 = 22
    printNewlines(1);
    
    // Dynamic step (negative)
    sum = 0;
    for (int i = 10, 1, s2) {
        sum = sum + i;
    }
    printInt(sum); // 10 + 7 + 4 + 1 = 22
    printNewlines(1);
    
    return 0;
}
