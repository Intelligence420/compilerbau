extern void printInt(int val);
extern void printNewlines(int num);

export int main() {
    int sum = 0;
    int s1 = 3;
    int s2 = -3;
    
    // Normal loop
    for (int i = 1, 10) {
        sum = sum + i;
    }
    printInt(sum); // (9*10)/2 = 45 (1 to 9)
    printNewlines(1);
    
    // Loop with explicit step
    sum = 0;
    for (int i = 0, 10, 2) {
        sum = sum + i;
    }
    printInt(sum); // 0+2+4+6+8 = 20
    printNewlines(1);
    
    // Reverse loop
    sum = 0;
    for (int i = 10, 1, -2) {
        sum = sum + i;
    }
    printInt(sum); // 10+8+6+4+2 = 30 (10 down to 2)
    printNewlines(1);
    
    // Dynamic step
    sum = 0;
    for (int i = 1, 10, s1) {
        sum = sum + i;
    }
    printInt(sum); // 1 + 4 + 7 = 12
    printNewlines(1);
    
    // Dynamic step (negative)
    sum = 0;
    for (int i = 10, 1, s2) {
        sum = sum + i;
    }
    printInt(sum); // 10 + 7 + 4 = 21
    printNewlines(1);
    
    return 0;
}
