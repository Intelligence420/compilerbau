extern void printInt(int val);
extern void printNewlines(int num);

export int main() {
    int[10] arr;
    int i = 0;
    while (i < 10) {
        arr[i] = i * i;
        i = i + 1;
    }
    
    i = 0;
    while (i < 10) {
        printInt(arr[i]);
        printNewlines(1);
        i = i + 1;
    }

    return 0;
}
