extern void printInt(int val);
extern void printFloat(float val);
extern void printNewlines(int num);

export int main() {
    int a = 10;
    int b = 3;
    float f1 = 1.5;
    float f2 = 2.0;

    printInt(a + b);
    printNewlines(1);
    printInt(a - b);
    printNewlines(1);
    printInt(a * b);
    printNewlines(1);
    printInt(a / b);
    printNewlines(1);
    printInt(a % b);
    printNewlines(1);

    printFloat(f1 + f2);
    printNewlines(1);
    printFloat(f1 - f2);
    printNewlines(1);
    printFloat(f1 * f2);
    printNewlines(1);
    printFloat(f1 / f2);
    printNewlines(1);

    return 0;
}
