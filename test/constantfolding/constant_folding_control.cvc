export int main() {
    int x = 0;
    if (1 + 1 == 2) {
        x = 1;
    } else {
        x = 2;
    }

    // While condition should be folded to false
    while (5 < 4) {
        x = 5 + 1;
    }

    // Do-while condition should be folded to false
    do {
        x = x - 1;
    } while (false && true);

    // For loop init and until should be folded
    for (int i = 0, 10 + 5) {
        x = x + i;
    }

    return x;
}
