export int main() {
    // Basic Arithmetic
    int i = (1 + 2) * 3 - (10 / 2) % 3; // (3*3) - (5%3) = 9 - 2 = 7
    float f = 1.5 * 2.0 + 10.0 / 4.0;   // 3.0 + 2.5 = 5.5
    bool b = true && (false || !false); // true && (false || true) = true
    
    // Comparisons
    bool c1 = 10 < 20;     // true
    bool c2 = 10.0 >= 10.0; // true
    bool c3 = true == false; // false
    
    // Type Casts
    int t1 = (int)5.9;      // 5
    float t2 = (float)10;   // 10.0
    bool t3 = (bool)0.0;    // false
    bool t4 = (bool)123;    // true
    
    // Array Expressions
    int[3] arr = [1+1, 2+2, 3+3]; // [2, 4, 6]
    
    // Unary chain
    int u = - - - -5; // 5
    
    // Bool math (if allowed by language)
    bool bm = true + false * true; // true + (false * true) = true + false = true
    
    // Nested mixed
    float mixed = (float)(10 / 3) + 0.5; // (float)3 + 0.5 = 3.5

    int y = 1 + 2 -3 + 4+ 5 +6+ 7+ 8+ 9+ 9+ 9+ 9+ 9;

    int x = 0;
    x = x + 1;
    x = x + 1;
    x = x + 1;
    x = x + 1;
    x = x + 1;
    x = x + 1;
    x = x + 1;
    
    return i;
}
