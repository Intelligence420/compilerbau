extern void printInt(int val);
extern void printNewlines(int n);

export int main() {
  int a = 10;
  int b = 1;
  int c = -3;

  c = a + 3;

  // 1. Standard inclusive loop (0 to 10)
  for (int i = 0, 10) {
    printInt(i);
  }
  printNewlines(1);

  // 2. Positive step > 1 (0, 2, 4, 6, 8, 10)
  for (int i = 0, 10, 2) {
    printInt(i);
  }
  printNewlines(1);

  // 3. Negative step (5, 2)
  for (int j = 5, 1, -3) {
    printInt(j);
  }
  printNewlines(1);

  // 4. bis 0
  for (int i = 10, 0) {
    printInt(i);
  }
  printNewlines(1);

  // 5. negative step
  for (int i = 0, 10, -1) {
    printInt(i);
  }
  printNewlines(1);

  // 6. Nested loops
  for (int i = 0, 1) {
    for (int j = 0, 1) {
      printInt(i * 10 + j);
    }
  }
  printNewlines(1);

  for (int j = a, b, c) {
    printInt(j);
  }
  printNewlines(1);

  return 0;
}
